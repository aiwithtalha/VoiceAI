# =============================================================================
# Universal Voice AI Platform - Environment Variables
# Phase 1: Local Development Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# ==========================================
# Database Configuration
# ==========================================
# PostgreSQL connection string (used by Prisma)
DATABASE_URL=postgresql://voiceai:your_secure_password@localhost:5432/voiceai_platform?schema=public

# PostgreSQL Docker container credentials
POSTGRES_USER=voiceai
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=voiceai_platform

# ==========================================
# Redis Configuration
# ==========================================
# Redis connection URL
REDIS_URL=redis://:your_redis_password@localhost:6379

# Redis password (for Docker container)
REDIS_PASSWORD=your_redis_password

# ==========================================
# Authentication (NextAuth.js)
# ==========================================
# JWT secret for token signing (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here

# ==========================================
# OAuth Providers - Google
# ==========================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==========================================
# OAuth Providers - LinkedIn
# ==========================================
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ==========================================
# Twilio (Voice Infrastructure)
# ==========================================
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_API_KEY=SK_your_api_key
TWILIO_API_SECRET=your_api_secret

# ==========================================
# Deepgram (Speech-to-Text)
# ==========================================
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key

# ==========================================
# ElevenLabs (Text-to-Speech)
# ==========================================
# Get from: https://elevenlabs.io/app/settings/api
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ==========================================
# OpenAI (AI/LLM)
# ==========================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key

# ==========================================
# Anthropic (AI/LLM - Optional)
# ==========================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ==========================================
# Stripe (Payments)
# ==========================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_price_id

# ==========================================
# Application URLs
# ==========================================
# Local development URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
VOICE_ENGINE_URL=http://localhost:3002

# Production URLs (update for production deployment)
# APP_URL=https://yourdomain.com
# API_URL=https://api.yourdomain.com
# VOICE_ENGINE_URL=https://voice.yourdomain.com

# ==========================================
# Optional: Admin Tools
# ==========================================
# pgAdmin credentials (only used when running with --profile tools)
PGADMIN_EMAIL=admin@voiceai.local
PGADMIN_PASSWORD=admin

# ==========================================
# Optional: Feature Flags
# ==========================================
# Enable/disable features in development
ENABLE_VOICE_DEBUG=true
ENABLE_AI_LOGGING=false
ENABLE_STRIPE_TEST_MODE=true

# ==========================================
# Optional: Monitoring & Logging
# ==========================================
# Log level: debug, info, warn, error
LOG_LEVEL=debug

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn

# Optional: Analytics
# POSTHOG_API_KEY=your_posthog_key
# POSTHOG_HOST=https://app.posthog.com
