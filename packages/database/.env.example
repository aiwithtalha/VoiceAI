# Database Configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voice_ai_platform"

# For connection pooling (production)
DATABASE_URL_POOL="postgresql://postgres:postgres@localhost:5432/voice_ai_platform?connection_limit=20"

# Direct connection for migrations
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/voice_ai_platform"

# Environment
NODE_ENV="development"
